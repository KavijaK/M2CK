- name: epy_block_2
  id: epy_block
  parameters:
    _source_code: "import pmt\nfrom gnuradio import gr\n\nARQ_HEADER_SIZE = 4  # [SEQ][FLAGS][SRC_ID][DST_ID]\n\
      \n\nclass blk(gr.basic_block):\n    \"\"\"\n    Frame classifier for ARQ frames.\n\
      \n    Input (message port 'in'):\n        PDU (meta, u8vector) representing\
      \ one ARQ frame:\n          byte 0 : SEQ\n          byte 1 : FLAGS   (bit0 =\
      \ LAST_FRAME, bit1 = IS_ACK)\n          byte 2 : SRC_ID\n          byte 3 :\
      \ DST_ID\n          byte 4.. : payload (zero-padded)\n\n    Outputs:\n     \
      \   'ack_out' : PDU forwarded if frame is an ACK (IS_ACK = 1)\n        'msg_out'\
      \ : PDU forwarded if frame is DATA  (IS_ACK = 0)\n\n    The payload is not modified;\
      \ the whole frame is passed through.\n    \"\"\"\n\n    def __init__(self, label=\"\
      frame_classifier\"):\n        gr.basic_block.__init__(\n            self,\n\
      \            name=\"frame_classifier\",\n            in_sig=None,\n        \
      \    out_sig=None,\n        )\n\n        self.label = str(label)\n\n       \
      \ # Ports\n        self.message_port_register_in(pmt.intern(\"in\"))\n     \
      \   self.message_port_register_out(pmt.intern(\"ack_out\"))\n        self.message_port_register_out(pmt.intern(\"\
      msg_out\"))\n\n        self.set_msg_handler(pmt.intern(\"in\"), self.handle_pdu)\n\
      \n    def handle_pdu(self, pdu):\n        meta = pmt.car(pdu)\n        vec \
      \ = pmt.cdr(pdu)\n\n        if not pmt.is_u8vector(vec):\n            print(f\"\
      [{self.label}] ERROR: payload is not u8vector\")\n            return\n\n   \
      \     data = bytes(pmt.u8vector_elements(vec))\n        n    = len(data)\n\n\
      \        if n < ARQ_HEADER_SIZE:\n            print(f\"[{self.label}] ERROR:\
      \ frame too short ({n} bytes)\")\n            return\n\n        seq   = data[0]\n\
      \        flags = data[1]\n        src   = data[2]\n        dst   = data[3]\n\
      \n        is_last = (flags >> 0) & 0x01\n        is_ack  = (flags >> 1) & 0x01\n\
      \n        # Optional debug\n        print(f\"[{self.label}] frame len={n}, SEQ={seq},\
      \ \"\n              f\"FLAGS=0x{flags:02X} (last={is_last}, ack={is_ack}), \"\
      \n              f\"SRC={src}, DST={dst}\")\n\n        if is_ack:\n         \
      \   # ACK frame \u2192 send to ack_out (for arq_framer.ack_in path)\n      \
      \      self.message_port_pub(pmt.intern(\"ack_out\"), pdu)\n        else:\n\
      \            # DATA frame \u2192 send to msg_out (for message_reassembler path)\n\
      \            self.message_port_pub(pmt.intern(\"msg_out\"), pdu)\n"
    affinity: ''
    alias: ''
    comment: ''
    label: '"frame_classifier"'
    maxoutbuf: '0'
    minoutbuf: '0'
  states:
    _io_cache: '(''frame_classifier'', ''blk'', [(''label'', "''frame_classifier''")],
