- name: epy_block_0
  id: epy_block
  parameters:
    _source_code: "import numpy as np\nfrom gnuradio import gr\nimport pmt\n\n\nclass\
      \ blk(gr.sync_block):\n    \"\"\"\n    Message assembler for GUI chat packets.\n\
      \n    Input:  byte stream (np.uint8) from ZMQ SUB Source\n    Output: PDUs on\
      \ 'msg_out', each PDU is a complete GUI packet:\n            [src_id][dst_id][len_hi][len_lo][payload...]\n\
      \n    Packet format (from GUI):\n      byte 0: src_id       (uint8)\n      byte\
      \ 1: dst_id       (uint8)\n      byte 2: len_hi       (uint8)\n      byte 3:\
      \ len_lo       (uint8)\n      bytes 4..(4+len-1): payload bytes (UTF-8 text)\n\
      \    \"\"\"\n\n    def __init__(self):\n        gr.sync_block.__init__(\n  \
      \          self,\n            name=\"message_assembler\",\n            in_sig=[np.uint8],\n\
      \            out_sig=None,  # no stream output; only PDUs\n        )\n\n   \
      \     # Internal buffer to accumulate bytes across work() calls\n        self._buf\
      \ = bytearray()\n\n        # Register output message port\n        self.message_port_register_out(pmt.intern(\"\
      msg_out\"))\n\n    def work(self, input_items, output_items):\n        in0 =\
      \ input_items[0]\n        n = len(in0)\n\n        if n == 0:\n            return\
      \ 0\n\n        # Append new bytes from the stream into our buffer\n        self._buf.extend(in0.tobytes())\n\
      \n        # Try to extract as many complete packets as possible\n        while\
      \ True:\n            # Need at least 4 bytes for header: src, dst, len_hi, len_lo\n\
      \            if len(self._buf) < 4:\n                break\n\n            src_id\
      \ = self._buf[0]\n            dst_id = self._buf[1]\n            length = (self._buf[2]\
      \ << 8) | self._buf[3]\n\n            # Sanity check on length (optional, but\
      \ helpful)\n            if length < 0 or length > 65535:\n                print(\"\
      [message_assembler] Invalid length field:\", length)\n                self._buf.clear()\n\
      \                break\n\n            # Do we have the full payload yet?\n \
      \           needed = 4 + length\n            if len(self._buf) < needed:\n \
      \               # Not enough data yet; wait for next work() call\n         \
      \       break\n\n            # Extract one complete GUI packet\n           \
      \ pkt_bytes = self._buf[:needed]\n            # Remove it from the buffer\n\
      \            del self._buf[:needed]\n\n            # Convert to a list of ints\
      \ for init_u8vector\n            pkt_list = [int(b) for b in pkt_bytes]\n\n\
      \            # Wrap as a PDU: (dict, u8vector)\n            meta = pmt.make_dict()\
      \  # no metadata for now\n            vec = pmt.init_u8vector(len(pkt_list),\
      \ pkt_list)\n            pdu = pmt.cons(meta, vec)\n\n            # Publish\
      \ the packet\n            self.message_port_pub(pmt.intern(\"msg_out\"), pdu)\n\
      \n            # Optional debug print\n            # print(f\"[message_assembler]\
      \ Emitted packet: src={src_id}, dst={dst_id}, len={length}\")\n\n        # We\
      \ always consume all input samples\n        return n\n"
    affinity: ''
    alias: ''
    comment: ''
    maxoutbuf: '0'
    minoutbuf: '0'
  states:
    _io_cache: '(''message_assembler'', ''blk'', [], [(''0'', ''byte'', 1)], [(''msg_out'',
      ''message'', 1)], "\n    Message assembler for GUI chat packets.\n\n    Input:  byte
      stream (np.uint8) from ZMQ SUB Source\n    Output: PDUs on ''msg_out'', each
      PDU is a complete GUI packet:\n            [src_id][dst_id][len_hi][len_lo][payload...]\n\n    Packet
      format (from GUI):\n      byte 0: src_id       (uint8)\n      byte 1: dst_id       (uint8)\n      byte
      2: len_hi       (uint8)\n      byte 3: len_lo       (uint8)\n      bytes 4..(4+len-1):
      payload bytes (UTF-8 text)\n    ", [])'
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [304, 220.0]
    rotation: 0
    state: enabled
- name: epy_block_1
  id: epy_block
  parameters:
    _source_code: "import numpy as np\nfrom gnuradio import gr\nimport pmt\nimport\
      \ time\nimport threading\n\n# ARQ frame contributed by this framer (before protocol\
      \ formatter + CRC)\n# RF frame: 12B header + 48B ARQ frame + 4B CRC = 64 bytes\
      \ total\nARQ_FRAME_SIZE   = 48          # bytes from this block\nARQ_HEADER_SIZE\
      \  = 4           # [SEQ][FLAGS][SRC_ID][DST_ID]\nARQ_PAYLOAD_SIZE = ARQ_FRAME_SIZE\
      \ - ARQ_HEADER_SIZE  # 44 bytes\n\n\nclass blk(gr.basic_block):\n    \"\"\"\n\
      \    Stop-and-wait ARQ framer with fixed 48-byte frames (for 64B RF frame).\n\
      \n    Upstream message format (from message_assembler on 'data_in'):\n     \
      \   [src_id][dst_id][len_hi][len_lo][payload...]\n\n    Framer output (on 'frame_out'):\
      \ fixed 48-byte ARQ frames:\n        byte 0   : SEQ        (uint8)\n       \
      \ byte 1   : FLAGS      (bit0 = LAST_FRAME, bit1 = IS_ACK, others 0)\n     \
      \   byte 2   : SRC_ID     (uint8)\n        byte 3   : DST_ID     (uint8)\n \
      \       byte 4.. : payload chunk (up to 44 bytes, zero-padded)\n\n    Notes:\n\
      \      - No preamble, no length, no CRC here.\n        Protocol formatter (12B\
      \ header) and CRC (4B) are applied later to\n        reach 64B total on the\
      \ air.\n      - Fragmentation is done over the entire upstream message.\n  \
      \    - ACK frames use the same 48B format with IS_ACK=1 and empty payload.\n\
      \n    Retransmission behavior in this implementation:\n      - For each DATA\
      \ frame (one fragment):\n          * Build the 48B frame once.\n          *\
      \ Continuously transmit that same frame on \"frame_out\" as a stream\n     \
      \       until either:\n              - a matching ACK is received, OR\n    \
      \          - the retry limit for that frame is reached.\n      - retry limit\
      \ per frame:\n          * repeat_enable = False  -> 1 transmit (no extra retries)\n\
      \          * repeat_enable = True   -> repeat_count total transmits for that\
      \ frame\n      - Stop-and-wait is preserved: next fragment is not started until\
      \ ACK\n        for the current SEQ is accepted (or you\u2019ve exhausted retries\
      \ and\n        you decide what to do at a higher layer).\n    \"\"\"\n\n   \
      \ def __init__(self, repeat_enable=False, repeat_count=1):\n        gr.basic_block.__init__(\n\
      \            self,\n            name=\"arq_framer\",\n            in_sig=None,\n\
      \            out_sig=None,\n        )\n\n        # --- Parameters ---\n    \
      \    self.repeat_enable = bool(repeat_enable)\n        self.repeat_count  =\
      \ max(1, int(repeat_count))\n\n        # --- ARQ state ---\n        self._seq\
      \             = 0          # current SEQ (uint8)\n        self._current_msg\
      \     = None       # bytes: full message from data_in\n        self._msg_len\
      \         = 0\n        self._offset          = 0          # how many bytes already\
      \ sent from msg\n        self._last_chunk_len  = 0          # last payload chunk\
      \ length\n        self._waiting_for_ack = False\n\n        self._src_id    \
      \      = 0\n        self._dst_id          = 0\n\n        # Keep original metadata\
      \ to propagate downstream if needed\n        self._current_meta    = pmt.PMT_NIL\n\
      \n        # Retransmission state:\n        #   _current_frame_pdu : last frame\
      \ we are actively trying to get ACK for\n        #   _retries_left      : how\
      \ many more times we'll transmit this frame\n        #   _resend_interval  \
      \ : small delay between transmits (behaves like stream)\n        self._current_frame_pdu\
      \ = None\n        self._retries_left      = 0\n        self._resend_interval\
      \   = 0.001  # seconds; small -> almost continuous\n\n        # --- Message\
      \ ports ---\n        self.message_port_register_in(pmt.intern(\"data_in\"))\n\
      \        self.message_port_register_in(pmt.intern(\"ack_in\"))\n        self.message_port_register_out(pmt.intern(\"\
      frame_out\"))\n\n        self.set_msg_handler(pmt.intern(\"data_in\"), self.handle_data_pdu)\n\
      \        self.set_msg_handler(pmt.intern(\"ack_in\"),  self.handle_ack_pdu)\n\
      \n        # Background retransmission loop: keeps re-sending current frame\n\
      \        self._tx_thread = threading.Thread(\n            target=self._retransmit_loop,\n\
      \            daemon=True,\n        )\n        self._tx_thread.start()\n\n  \
      \  # ------------------------------------------------------------------\n  \
      \  # Background: retransmission loop\n    # ------------------------------------------------------------------\n\
      \    def _retransmit_loop(self):\n        \"\"\"\n        Continuously streams\
      \ the current frame while we are waiting for ACK:\n          - If _waiting_for_ack\
      \ is True, _current_frame_pdu is not None,\n            and _retries_left >\
      \ 0:\n              * send that PDU on frame_out\n              * decrement\
      \ _retries_left\n          - Stops sending when:\n              * ACK handler\
      \ clears _waiting_for_ack, OR\n              * _retries_left reaches 0.\n  \
      \      \"\"\"\n        port_sym = pmt.intern(\"frame_out\")\n\n        while\
      \ True:\n            if (\n                self._waiting_for_ack\n         \
      \       and self._current_frame_pdu is not None\n                and self._retries_left\
      \ > 0\n            ):\n                # Transmit the current frame again\n\
      \                print(\"Frame transmitted\")\n                self.message_port_pub(port_sym,\
      \ self._current_frame_pdu)\n                self._retries_left -= 1\n\n    \
      \            # Very small pause to avoid completely hogging CPU,\n         \
      \       # but still essentially \"streaming\".\n                time.sleep(self._resend_interval)\n\
      \n            else:\n                # Either not waiting, or no frame, or retries\
      \ exhausted.\n                # Just idle a bit.\n                time.sleep(0.001)\n\
      \n    # ------------------------------------------------------------------\n\
      \    # DATA from upper layer (new message to send)\n    # ------------------------------------------------------------------\n\
      \    def handle_data_pdu(self, pdu):\n        \"\"\"\n        Accept a new higher-layer\
      \ message to be fragmented and sent.\n\n        Input PDU: (meta, u8vector)\n\
      \        Bytes: [src_id][dst_id][len_hi][len_lo][payload...]\n\n        We fragment\
      \ the entire message into ARQ frames, but also copy src_id\n        and dst_id\
      \ into every frame header for convenience.\n        \"\"\"\n        if self._waiting_for_ack\
      \ or self._current_msg is not None:\n            print(\"[arq_framer] Busy (waiting\
      \ for ACK or message in progress); \"\n                  \"ignoring new data_in\
      \ PDU.\")\n            return\n\n        meta = pmt.car(pdu)\n        vec  =\
      \ pmt.cdr(pdu)\n\n        if not pmt.is_u8vector(vec):\n            print(\"\
      [arq_framer] data_in: expected u8vector\")\n            return\n\n        msg\
      \ = bytes(bytearray(pmt.u8vector_elements(vec)))\n        if len(msg) == 0:\n\
      \            print(\"[arq_framer] data_in: empty message, ignoring\")\n    \
      \        return\n\n        # Extract SRC and DST from message as produced by\
      \ message_assembler\n        if len(msg) >= 2:\n            self._src_id = msg[0]\n\
      \            self._dst_id = msg[1]\n        else:\n            self._src_id\
      \ = 0\n            self._dst_id = 0\n            print(\"[arq_framer] Warning:\
      \ message too short to extract src/dst, \"\n                  \"using 0/0\"\
      )\n\n        self._current_msg       = msg\n        self._msg_len          \
      \ = len(msg)\n        self._offset            = 0\n        self._last_chunk_len\
      \    = 0\n        self._waiting_for_ack   = False\n        self._current_meta\
      \      = meta\n        self._current_frame_pdu = None\n        self._retries_left\
      \      = 0\n\n        print(f\"[arq_framer] New message len={self._msg_len},\
      \ \"\n              f\"src={self._src_id}, dst={self._dst_id}, starting at SEQ={self._seq}\"\
      )\n\n        # Kick off first fragment; retransmit loop will handle streaming\n\
      \        self._send_next_frame()\n\n    # ------------------------------------------------------------------\n\
      \    # ACK from RX side\n    # ------------------------------------------------------------------\n\
      \    def handle_ack_pdu(self, pdu):\n        \"\"\"\n        Handle an incoming\
      \ ACK frame.\n\n        We assume ACK PDU payload is also a 48-byte ARQ frame:\n\
      \            [SEQ][FLAGS][SRC][DST][zeros...]\n\n        We check:\n       \
      \   - IS_ACK flag\n          - SEQ matches current SEQ\n        \"\"\"\n   \
      \     if not self._waiting_for_ack or self._current_msg is None:\n         \
      \   print(\"[arq_framer] Received ACK while not waiting; ignoring\")\n     \
      \       return\n\n        vec = pmt.cdr(pdu)\n\n        if not pmt.is_u8vector(vec):\n\
      \            print(\"[arq_framer] ack_in: expected u8vector\")\n           \
      \ return\n\n        data = bytes(bytearray(pmt.u8vector_elements(vec)))\n  \
      \      if len(data) < ARQ_HEADER_SIZE:\n            print(\"[arq_framer] ack_in:\
      \ frame too short:\", len(data))\n            return\n\n        seq_ack = data[0]\n\
      \        flags   = data[1]\n\n        is_ack  = (flags >> 1) & 0x01\n\n    \
      \    if not is_ack:\n            print(f\"[arq_framer] ack_in: received non-ACK\
      \ frame (flags=0x{flags:02X}), ignoring\")\n            return\n\n        expected_seq\
      \ = self._seq & 0xFF\n        if seq_ack != expected_seq:\n            print(f\"\
      [arq_framer] ack_in: SEQ mismatch (expected={expected_seq}, \"\n           \
      \       f\"got={seq_ack}), ignoring\")\n            return\n\n        print(f\"\
      [arq_framer] ACK received for SEQ={seq_ack}\")\n\n        # ACK matches: stop\
      \ retransmissions for this frame\n        self._waiting_for_ack   = False\n\
      \        self._current_frame_pdu = None\n        self._retries_left      = 0\n\
      \n        # Move offset by last chunk size\n        self._offset += self._last_chunk_len\n\
      \        self._last_chunk_len = 0\n\n        # Advance SEQ\n        self._seq\
      \ = (self._seq + 1) & 0xFF\n\n        # Send next frame or finish message\n\
      \        self._send_next_frame()\n\n    # ------------------------------------------------------------------\n\
      \    # Internal: build and prepare the next fragment (streamed by loop)\n  \
      \  # ------------------------------------------------------------------\n  \
      \  def _send_next_frame(self):\n        # No active message\n        if self._current_msg\
      \ is None:\n            self._waiting_for_ack   = False\n            self._current_frame_pdu\
      \ = None\n            self._retries_left      = 0\n            return\n\n  \
      \      # Message fully sent\n        if self._offset >= self._msg_len:\n   \
      \         print(\"[arq_framer] Message complete\")\n            self._current_msg\
      \       = None\n            self._msg_len           = 0\n            self._offset\
      \            = 0\n            self._last_chunk_len    = 0\n            self._waiting_for_ack\
      \   = False\n            self._current_meta      = pmt.PMT_NIL\n           \
      \ self._current_frame_pdu = None\n            self._retries_left      = 0\n\
      \            return\n\n        # Determine next payload chunk\n        remaining\
      \ = self._msg_len - self._offset\n        chunk_len = min(remaining, ARQ_PAYLOAD_SIZE)\n\
      \        chunk     = self._current_msg[self._offset : self._offset + chunk_len]\n\
      \n        is_last = 1 if (self._offset + chunk_len) >= self._msg_len else 0\n\
      \n        last_bit = is_last & 0x01\n        is_ack   = 0  # data frame\n  \
      \      flags    = (last_bit << 0) | (is_ack << 1)\n\n        seq = self._seq\
      \ & 0xFF\n\n        # Build fixed-size 48-byte ARQ frame\n        frame = bytearray(ARQ_FRAME_SIZE)\n\
      \        frame[0] = seq\n        frame[1] = flags\n        frame[2] = self._src_id\
      \ & 0xFF\n        frame[3] = self._dst_id & 0xFF\n        frame[4:4 + chunk_len]\
      \ = chunk  # rest stays zero-padded\n\n        frame_bytes = bytes(frame)\n\n\
      \        out_meta = self._current_meta\n        out_vec  = pmt.init_u8vector(len(frame_bytes),\
      \ list(frame_bytes))\n        out_pdu  = pmt.cons(out_meta, out_vec)\n\n   \
      \     # Store current frame for retransmissions\n        self._current_frame_pdu\
      \ = out_pdu\n\n        # Total transmits for THIS frame:\n        # - if repeat_enable\
      \ == False -> 1 attempt\n        # - if repeat_enable == True  -> repeat_count\
      \ attempts\n        if self.repeat_enable:\n            self._retries_left =\
      \ max(1, int(self.repeat_count))\n        else:\n            self._retries_left\
      \ = 1\n\n        self._last_chunk_len  = chunk_len\n        self._waiting_for_ack\
      \ = True\n\n        print(f\"[arq_framer] Prepared frame SEQ={seq}, chunk_len={chunk_len},\
      \ \"\n              f\"last={is_last}, retries_limit={self._retries_left}, waiting\
      \ for ACK\")\n"
    affinity: ''
    alias: ''
    comment: ''
    maxoutbuf: '0'
    minoutbuf: '0'
    repeat_count: '1000'
    repeat_enable: 'True'
  states:
    _io_cache: "('arq_framer', 'blk', [('repeat_enable', 'False'), ('repeat_count',\
      \ '1')], [('data_in', 'message', 1), ('ack_in', 'message', 1)], [('frame_out',\
      \ 'message', 1)], '\\n    Stop-and-wait ARQ framer with fixed 48-byte frames\
      \ (for 64B RF frame).\\n\\n    Upstream message format (from message_assembler\
      \ on \\'data_in\\'):\\n        [src_id][dst_id][len_hi][len_lo][payload...]\\\
      n\\n    Framer output (on \\'frame_out\\'): fixed 48-byte ARQ frames:\\n   \
      \     byte 0   : SEQ        (uint8)\\n        byte 1   : FLAGS      (bit0 =\
      \ LAST_FRAME, bit1 = IS_ACK, others 0)\\n        byte 2   : SRC_ID     (uint8)\\\
      n        byte 3   : DST_ID     (uint8)\\n        byte 4.. : payload chunk (up\
      \ to 44 bytes, zero-padded)\\n\\n    Notes:\\n      - No preamble, no length,\
      \ no CRC here.\\n        Protocol formatter (12B header) and CRC (4B) are applied\
      \ later to\\n        reach 64B total on the air.\\n      - Fragmentation is\
      \ done over the entire upstream message.\\n      - ACK frames use the same 48B\
      \ format with IS_ACK=1 and empty payload.\\n\\n    Retransmission behavior in\
      \ this implementation:\\n      - For each DATA frame (one fragment):\\n    \
      \      * Build the 48B frame once.\\n          * Continuously transmit that\
      \ same frame on \"frame_out\" as a stream\\n            until either:\\n   \
      \           - a matching ACK is received, OR\\n              - the retry limit\
      \ for that frame is reached.\\n      - retry limit per frame:\\n          *\
      \ repeat_enable = False  -> 1 transmit (no extra retries)\\n          * repeat_enable\
      \ = True   -> repeat_count total transmits for that frame\\n      - Stop-and-wait\
      \ is preserved: next fragment is not started until ACK\\n        for the current\
      \ SEQ is accepted (or you\u2019ve exhausted retries and\\n        you decide\
      \ what to do at a higher layer).\\n    ', ['repeat_count', 'repeat_enable'])"
