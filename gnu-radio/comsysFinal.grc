- name: epy_block_3
  id: epy_block
  parameters:
    _source_code: "import pmt\nfrom gnuradio import gr\n\nARQ_FRAME_SIZE   = 48\n\
      ARQ_HEADER_SIZE  = 4  # [SEQ][FLAGS][SRC][DST]\n\n\nclass blk(gr.basic_block):\n\
      \    \"\"\"\n    Message reassembler for stop-and-wait ARQ frames with duplicate\
      \ filtering.\n\n    Input (message port 'in'):\n        - DATA ARQ frames as\
      \ PDUs:\n          [SEQ][FLAGS][SRC][DST][payload (0-padded)]\n\n    Internal\
      \ behavior:\n        - Appends payload bytes from each DATA frame (starting\
      \ at byte 4)\n          into an internal buffer.\n        - When a frame with\
      \ LAST_FRAME=1 arrives:\n            * interpret buffer as:\n              \
      \  [src_id][dst_id][len_hi][len_lo][payload...][padding...]\n            * compute\
      \ total message length = 4 + msg_len\n            * trim padding\n         \
      \   * compare with last delivered message:\n                - if identical ->\
      \ drop (duplicate)\n                - if different -> emit to 'msg_out' and\
      \ remember it\n            * clear buffer for the next message.\n    \"\"\"\n\
      \n    def __init__(self, label=\"message_reassembler\"):\n        gr.basic_block.__init__(\n\
      \            self,\n            name=\"message_reassembler\",\n            in_sig=None,\n\
      \            out_sig=None,\n        )\n\n        self.label = str(label)\n\n\
      \        self.message_port_register_in(pmt.intern(\"in\"))\n        self.message_port_register_out(pmt.intern(\"\
      msg_out\"))\n\n        self.set_msg_handler(pmt.intern(\"in\"), self.handle_pdu)\n\
      \n        # Buffer for assembling one complete message\n        self._buf =\
      \ bytearray()\n        self._assembling = False\n\n        # Last delivered\
      \ full message bytes (for duplicate suppression)\n        self._last_msg_bytes\
      \ = None\n\n    def handle_pdu(self, pdu):\n        meta = pmt.car(pdu)\n  \
      \      vec  = pmt.cdr(pdu)\n\n        if not pmt.is_u8vector(vec):\n       \
      \     print(f\"[{self.label}] ERROR: payload is not u8vector\")\n          \
      \  return\n\n        frame = bytes(pmt.u8vector_elements(vec))\n        n  \
      \   = len(frame)\n\n        if n < ARQ_HEADER_SIZE:\n            print(f\"[{self.label}]\
      \ ERROR: ARQ frame too short ({n} bytes)\")\n            return\n\n        seq\
      \   = frame[0]\n        flags = frame[1]\n        src   = frame[2]\n       \
      \ dst   = frame[3]\n\n        is_last = (flags >> 0) & 0x01\n        is_ack\
      \  = (flags >> 1) & 0x01\n\n        if is_ack:\n            # Should not see\
      \ ACKs here if wired correctly\n            print(f\"[{self.label}] WARNING:\
      \ received ACK frame on reassembler, ignoring\")\n            return\n\n   \
      \     # Payload chunk (with zero padding)\n        payload_chunk = frame[ARQ_HEADER_SIZE:]\n\
      \n        # Start of a new message?\n        if not self._assembling:\n    \
      \        self._buf = bytearray()\n            self._assembling = True\n    \
      \        print(f\"[{self.label}] Starting new message assembly \"\n        \
      \          f\"(SEQ={seq}, SRC={src}, DST={dst})\")\n\n        # Append chunk\n\
      \        self._buf.extend(payload_chunk)\n\n        # If not last frame, just\
      \ wait for more\n        if not is_last:\n            print(f\"[{self.label}]\
      \ Appended chunk (len={len(payload_chunk)}), \"\n                  f\"buffered={len(self._buf)}\
      \ bytes, waiting for more frames\")\n            return\n\n        # Last frame:\
      \ reconstruct full message and emit (or drop as duplicate)\n        print(f\"\
      [{self.label}] Last frame received (SEQ={seq}), \"\n              f\"total buffered={len(self._buf)}\
      \ bytes\")\n\n        full_msg = bytes(self._buf)\n\n        if len(full_msg)\
      \ < 4:\n            print(f\"[{self.label}] ERROR: assembled message too short\
      \ \"\n                  f\"({len(full_msg)} bytes)\")\n            self._buf\
      \ = bytearray()\n            self._assembling = False\n            return\n\n\
      \        # Parse original message header:\n        # [src_id][dst_id][len_hi][len_lo][payload...]\n\
      \        src_id = full_msg[0]\n        dst_id = full_msg[1]\n        msg_len\
      \ = (full_msg[2] << 8) | full_msg[3]\n\n        total_needed = 4 + msg_len\n\
      \n        if total_needed > len(full_msg):\n            print(f\"[{self.label}]\
      \ WARNING: needed {total_needed} bytes, \"\n                  f\"but only {len(full_msg)}\
      \ available; truncating\")\n            total_needed = len(full_msg)\n\n   \
      \     msg_bytes = full_msg[:total_needed]\n\n        # ---------- DUPLICATE\
      \ SUPPRESSION ----------\n        if self._last_msg_bytes is not None and msg_bytes\
      \ == self._last_msg_bytes:\n            print(f\"[{self.label}] Duplicate complete\
      \ message detected; \"\n                  f\"dropping (src={src_id}, dst={dst_id},\
      \ len={msg_len})\")\n        else:\n            # Build output PDU for ZMQ PUB\
      \ (or any upper layer)\n            out_meta = pmt.make_dict()  # or propagate\
      \ some fields if you like\n            out_vec  = pmt.init_u8vector(len(msg_bytes),\
      \ list(msg_bytes))\n            out_pdu  = pmt.cons(out_meta, out_vec)\n\n \
      \           self.message_port_pub(pmt.intern(\"msg_out\"), out_pdu)\n\n    \
      \        print(f\"[{self.label}] Emitted reassembled message: \"\n         \
      \         f\"src={src_id}, dst={dst_id}, len={msg_len}\")\n\n            # Remember\
      \ this message as the last delivered one\n            self._last_msg_bytes =\
      \ msg_bytes\n        # -------------------------------------------\n\n     \
      \   # Reset for next message\n        self._buf = bytearray()\n        self._assembling\
      \ = False\n"
    affinity: ''
    alias: ''
    comment: ''
    label: '"message_reassembler"'
    maxoutbuf: '0'
    minoutbuf: '0'
  states:
    _io_cache: ('message_reassembler', 'blk', [('label', "'message_reassembler'")],
      [('in', 'message', 1)], [('msg_out', 'message', 1)], "\n    Message reassembler
      for stop-and-wait ARQ frames with duplicate filtering.\n\n    Input (message
      port 'in'):\n        - DATA ARQ frames as PDUs:\n          [SEQ][FLAGS][SRC][DST][payload
      (0-padded)]\n\n    Internal behavior:\n        - Appends payload bytes from
      each DATA frame (starting at byte 4)\n          into an internal buffer.\n        -
      When a frame with LAST_FRAME=1 arrives:\n            * interpret buffer as:\n                [src_id][dst_id][len_hi][len_lo][payload...][padding...]\n            *
      compute total message length = 4 + msg_len\n            * trim padding\n            *
      compare with last delivered message:\n                - if identical -> drop
      (duplicate)\n                - if different -> emit to 'msg_out' and remember
      it\n            * clear buffer for the next message.\n    ", ['label'])
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [832, 788.0]
    rotation: 0
    state: enabled
- name: epy_block_4
  id: epy_block
  parameters:
    _source_code: "import pmt\nfrom gnuradio import gr\n\nARQ_FRAME_SIZE   = 48\n\
      ARQ_HEADER_SIZE  = 4  # [SEQ][FLAGS][SRC][DST]\n\n\nclass blk(gr.basic_block):\n\
      \    \"\"\"\n    ACK generator for ARQ frames.\n\n    Input (message port 'in'):\n\
      \        - PDU (meta, u8vector) representing one DATA ARQ frame:\n         \
      \ [SEQ][FLAGS][SRC][DST][payload...]\n\n    Output (message port 'out'):\n \
      \       - PDU(s) that are ACK ARQ frames, ready to be sent through\n       \
      \   CRC Append \u2192 Protocol Formatter \u2192 radio.\n\n    ACK frame format\
      \ (48B):\n        byte 0 : SEQ       (copied from DATA frame)\n        byte\
      \ 1 : FLAGS     (LAST=1, IS_ACK=1 => 0x03)\n        byte 2 : SRC_ID    (original\
      \ DST_ID)\n        byte 3 : DST_ID    (original SRC_ID)\n        byte 4..47\
      \ : zeros\n\n    Parameters:\n        repeat_enable (bool) : if True, send ACK\
      \ repeat_count times\n        repeat_count  (int)  : number of repeats when\
      \ enabled\n    \"\"\"\n\n    def __init__(self, repeat_enable=False, repeat_count=1,\n\
      \                 label=\"ack_generator\"):\n        gr.basic_block.__init__(\n\
      \            self,\n            name=\"ack_generator\",\n            in_sig=None,\n\
      \            out_sig=None,\n        )\n\n        self.label = str(label)\n\n\
      \        self.repeat_enable = bool(repeat_enable)\n        self.repeat_count\
      \  = max(1, int(repeat_count))\n\n        # Ports\n        self.message_port_register_in(pmt.intern(\"\
      in\"))\n        self.message_port_register_out(pmt.intern(\"out\"))\n\n    \
      \    self.set_msg_handler(pmt.intern(\"in\"), self.handle_pdu)\n\n    def handle_pdu(self,\
      \ pdu):\n        meta = pmt.car(pdu)\n        vec  = pmt.cdr(pdu)\n\n      \
      \  if not pmt.is_u8vector(vec):\n            print(f\"[{self.label}] ERROR:\
      \ payload is not u8vector\")\n            return\n\n        data = bytes(pmt.u8vector_elements(vec))\n\
      \        n    = len(data)\n\n        if n < ARQ_HEADER_SIZE:\n            print(f\"\
      [{self.label}] ERROR: frame too short ({n} bytes)\")\n            return\n\n\
      \        seq   = data[0]\n        flags = data[1]\n        src   = data[2]\n\
      \        dst   = data[3]\n\n        is_ack = (flags >> 1) & 0x01\n        if\
      \ is_ack:\n            # Defensive: we shouldn't be fed ACKs on this path\n\
      \            print(f\"[{self.label}] WARNING: got ACK frame on ack_generator\
      \ input, ignoring\")\n            return\n\n        # --- Build ACK frame ---\n\
      \        ack_seq  = seq\n        last_bit = 1  # mark ACK as \"last\" for convenience\n\
      \        is_ack   = 1\n        ack_flags = (last_bit << 0) | (is_ack << 1) \
      \ # 0b0011 = 0x03\n\n        ack_src = dst  # swap src/dst\n        ack_dst\
      \ = src\n\n        frame = bytearray(ARQ_FRAME_SIZE)\n        frame[0] = ack_seq\
      \ & 0xFF\n        frame[1] = ack_flags & 0xFF\n        frame[2] = ack_src &\
      \ 0xFF\n        frame[3] = ack_dst & 0xFF\n        # bytes 4..47 remain zeros\n\
      \n        ack_bytes = bytes(frame)\n\n        # Metadata for ACK \u2014 you\
      \ can keep it empty or copy selected fields\n        ack_meta = pmt.make_dict()\n\
      \        ack_vec  = pmt.init_u8vector(len(ack_bytes), list(ack_bytes))\n   \
      \     ack_pdu  = pmt.cons(ack_meta, ack_vec)\n\n        repeats = self.repeat_count\
      \ if self.repeat_enable else 1\n\n        print(f\"[{self.label}] Generated\
      \ ACK for SEQ={ack_seq}, \"\n              f\"SRC={ack_src}, DST={ack_dst},\
      \ repeats={repeats}\")\n\n        for _ in range(repeats):\n            self.message_port_pub(pmt.intern(\"\
      out\"), ack_pdu)\n"
    affinity: ''
    alias: ''
    comment: ''
    label: '"ack_generator"'
    maxoutbuf: '0'
    minoutbuf: '0'
    repeat_count: '4'
    repeat_enable: 'True'
  states:
    _io_cache: "('ack_generator', 'blk', [('repeat_enable', 'False'), ('repeat_count',\
      \ '1'), ('label', \"'ack_generator'\")], [('in', 'message', 1)], [('out', 'message',\
      \ 1)], \"\\n    ACK generator for ARQ frames.\\n\\n    Input (message port 'in'):\\\
      n        - PDU (meta, u8vector) representing one DATA ARQ frame:\\n        \
      \  [SEQ][FLAGS][SRC][DST][payload...]\\n\\n    Output (message port 'out'):\\\
      n        - PDU(s) that are ACK ARQ frames, ready to be sent through\\n     \
      \     CRC Append \u2192 Protocol Formatter \u2192 radio.\\n\\n    ACK frame\
      \ format (48B):\\n        byte 0 : SEQ       (copied from DATA frame)\\n   \
      \     byte 1 : FLAGS     (LAST=1, IS_ACK=1 => 0x03)\\n        byte 2 : SRC_ID\
      \    (original DST_ID)\\n        byte 3 : DST_ID    (original SRC_ID)\\n   \
      \     byte 4..47 : zeros\\n\\n    Parameters:\\n        repeat_enable (bool)\
      \ : if True, send ACK repeat_count times\\n        repeat_count  (int)  : number\
      \ of repeats when enabled\\n    \", ['label', 'repeat_count', 'repeat_enable'])"
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [832, 844.0]
    rotation: 0
    state: enabled
- name: epy_block_5
  id: epy_block
  parameters:
    _source_code: "import pmt\nfrom gnuradio import gr\n\n\nclass blk(gr.basic_block):\n\
      \    \"\"\"\n    Simple PDU multiplexer:\n      - Input ports: 'data_in', 'ack_in'\n\
      \      - Output port: 'out'\n    For any PDU arriving on either input, it forwards\
      \ it to 'out'.\n    \"\"\"\n\n    def __init__(self):\n        gr.basic_block.__init__(\n\
      \            self,\n            name=\"pdu_mux\",\n            in_sig=None,\n\
      \            out_sig=None,\n        )\n\n        self.message_port_register_in(pmt.intern(\"\
      data_in\"))\n        self.message_port_register_in(pmt.intern(\"ack_in\"))\n\
      \        self.set_msg_handler(pmt.intern(\"data_in\"), self._handle_pdu)\n \
      \       self.set_msg_handler(pmt.intern(\"ack_in\"), self._handle_pdu)\n\n \
      \       self.message_port_register_out(pmt.intern(\"out\"))\n\n    def _handle_pdu(self,\
      \ pdu):\n        # Just forward any PDU to the output\n        self.message_port_pub(pmt.intern(\"\
      out\"), pdu)\n"
    affinity: ''
    alias: ''
    comment: ''
    maxoutbuf: '0'
    minoutbuf: '0'
  states:
    _io_cache: '(''pdu_mux'', ''blk'', [], [(''data_in'', ''message'', 1), (''ack_in'',
      ''message'', 1)], [(''out'', ''message'', 1)], "\n    Simple PDU multiplexer:\n      -
      Input ports: ''data_in'', ''ack_in''\n      - Output port: ''out''\n    For
      any PDU arriving on either input, it forwards it to ''out''.\n    ", [])'
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [904, 204.0]
    rotation: 0
    state: enabled
